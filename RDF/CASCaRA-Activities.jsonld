        {
          "@id": "ProductionDevelopment",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Production Development"
            },
            {
              "@language": "de",
              "@value": "Produktionsentwicklung"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "The manufacturing or production engineer's primary focus is to turn raw material into an updated or new product in the most effective, efficient & economic way possible.\r\nManufacturing Engineering is based on core industrial engineering and mechanical engineering skills, adding important elements from mechatronics, commerce, economics and business management.\r\nSource: https://en.wikipedia.org/wiki/Manufacturing_engineering"
          },
          "dcterms:modified": {
            "@value": "2020-10-29T12:15:18Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
