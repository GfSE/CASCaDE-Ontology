	<owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ProductionDevelopment">
		<rdfs:subClassOf rdf:resource="&cas-meta;Entity"/>
		<rdfs:label xml:lang="en">Production Development</rdfs:label>
		<rdfs:label xml:lang="de">Produktionsentwicklung</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2020-10-29T12:15:18Z</dcterms:modified>
		<skos:definition xml:lang="en">The manufacturing or production engineer&apos;s primary focus is to turn raw material into an updated or new product in the most effective, efficient &amp; economic way possible.
Manufacturing Engineering is based on core industrial engineering and mechanical engineering skills, adding important elements from mechatronics, commerce, economics and business management.
Source: https://en.wikipedia.org/wiki/Manufacturing_engineering</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ProductionDevelopment/CostCalculation">
		<rdfs:subClassOf rdf:resource="&prov;Activity"/>
