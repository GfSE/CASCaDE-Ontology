  </sh:NodeShape>
  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain/ManufacturingProcess/ManufacturingOperation">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-12-05T17:07:03Z</dcterms:modified>
    <rdfs:label xml:lang="de">Fertigungsvorgang</rdfs:label>
    <rdfs:label xml:lang="en">Manufacturing Operation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <skos:definition xml:lang="en">Represents a single or a group of manufacturing operations that lead to a finished, assembled product.</skos:definition>
    <skos:definition xml:lang="de">Stellt einen einzelnen oder eine Gruppe von Fertigungsvorgängen dar, die zu einem fertigen, montierten Produkt führen.</skos:definition>
  </owl:Class>
  <sh:NodeShape rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain/ManufacturingProcess/ManufacturingOperation_Shape">
    <sh:property rdf:resource="http://purl.org/dc/elements/1.1/description_Shape" />
