	<owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ConceptDefinition">
		<rdfs:subClassOf rdf:resource="&cas-meta;Entity"/>
		<rdfs:label xml:lang="en">Concept definition</rdfs:label>
		<rdfs:label xml:lang="de">Konzeptdefinition</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2022-02-18T11:17:54Z</dcterms:modified>
		<skos:definition xml:lang="en">In conceptual design, new products or systems are defined through requirements and specified through a functional structure in mechanical, electrics/electronics, and software domains. A logical structure specifies the future product architecture in order to implement the specified functions.
Besides new products, existing products may be changed or modified significantly to better comply with customer needs, or to attract new customers. Eventually, the product may be changed or adopted to comply to new standards, regulations or laws.
Conceptual design is usually performed at a high abstraction level and low level of detail, using parameter studies, system models, and rough geometry, if any.
For the Digital Data Package, model-based methods and data for product conceptual design are assumed.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/LongTermArchiving">
		<rdfs:subClassOf rdf:resource="&prov;Activity"/>
		<rdfs:label xml:lang="de">Langzeitarchivierung</rdfs:label>
		<rdfs:label xml:lang="en">Long-Term Archiving</rdfs:label>
		<skos:definition xml:lang="en">For long-term archiving, all product information must be configured and stored in a retrievable way. Product information includes domain-specifc models, relations between models and model entities, and meta-data about the documents and models.</skos:definition>
		<prov:used rdf:resource="&proc;JoiningProcess"/>
		<prov:used rdf:resource="&arch;Function"/>
		<prov:used rdf:resource="&arch;FunctionFailure"/>
		<prov:used rdf:resource="&arch;StakeholderRequirement"/>
		<prov:used rdf:resource="&arch;SystemRequirement"/>
		<prov:used rdf:resource="&mech;Body"/>
		<prov:used rdf:resource="&mech;JoiningElement"/>
		<prov:used rdf:resource="&mech;KinematicJoint"/>
		<prov:used rdf:resource="&mech;KinematicMechanism"/>
		<prov:used rdf:resource="&mech;Material"/>
		<prov:used rdf:resource="&mech;MechanicalComponent"/>
		<prov:used rdf:resource="&mech;ModelAnnotation"/>
		<prov:used rdf:resource="&sys;ComponentConnection"/>
		<prov:used rdf:resource="&sys;ComponentInterface"/>
		<prov:used rdf:resource="&sys;ComponentState"/>
		<prov:used rdf:resource="&sys;SystemComponent"/>
		<prov:used rdf:resource="&val;Displacement"/>
		<prov:used rdf:resource="&val;ValidationResult"/>
		<prov:used rdf:resource="&val;ValidationRun"/>
		<prov:used rdf:resource="&ver;VerificationResult"/>
		<prov:used rdf:resource="&ver;VerificationRun"/>
	</owl:Class>
	
	<owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain">
		<rdfs:subClassOf rdf:resource="&cas-meta;Entity"/>
		<rdfs:label xml:lang="en">Manufacturing &amp; Supply Chain</rdfs:label>
		<rdfs:label xml:lang="de">Produktion &amp; Lieferkette</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2021-11-24T10:35:16Z</dcterms:modified>
		<skos:definition xml:lang="en">Includes all activities related to source and manufacture a product in different companies, plants, or locations.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&mnf;PackagingLogistics">
		<rdfs:subClassOf rdf:resource="&prov;Activity"/>
		<rdfs:label xml:lang="en">Packaging &amp; Logistics</rdfs:label>
		<rdfs:label xml:lang="de">Verpackung &amp; Logistik</rdfs:label>
		<skos:definition xml:lang="en">Includes the definition of all kinds of packaging and transport equipment to ensure a product or its components will be supplied to their destination safely.</skos:definition>
		<prov:used rdf:resource="&proc;JoiningProcess"/>
		<prov:used rdf:resource="&fld;HydraulicPneumaticConnection"/>
		<prov:used rdf:resource="&fld;HydraulicPneumaticPort"/>
		<prov:used rdf:resource="&mech;Body"/>
		<prov:used rdf:resource="&mech;JoiningElement"/>
		<prov:used rdf:resource="&mech;Material"/>
		<prov:used rdf:resource="&mech;MechanicalComponent"/>
	</owl:Class>
	
	<owl:Class rdf:about="&mnf;PartsManufacturing">
		<rdfs:subClassOf rdf:resource="&prov;Activity"/>
		<rdfs:label xml:lang="en">Parts Manufacturing</rdfs:label>
		<rdfs:label xml:lang="de">Teilefertigung</rdfs:label>
		<skos:definition xml:lang="en">Manufacturing of single parts using a variety of production processes and methods, each with specific sets of data, such as CNC programs, bending specification, holes specifications, joining features, etc.</skos:definition>
		<prov:used rdf:resource="&mnf;ManufacturingEquipmentComponent"/>
