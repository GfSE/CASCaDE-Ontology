			<enitity>
				<idShort>Configuration</idShort>
				<displayName>
					<langStringNameType>
						<language>en</language>
						<text>Configuration</text>
					</langStringNameType>
					<langStringNameType>
						<language>de</language>
						<text>Konfiguration</text>
					</langStringNameType>
				</displayName>
				<description>
					<langStringTextType>
						<language>en</language>
						<text>Represents a configuration as a context for other elements to be valid. The datamodel allows selected elements to be related to a revision, i. e. mechanical components</text>
					</langStringTextType>
					<langStringTextType>
						<language>de</language>
						<text>Repräsentiert eine Konfiguration als Kontext, in dem verknüpfte Elemente gültig sein sollen. Das Datenmodell sieht vor, ausgewählte Elemente mit einer Konfiguration zu verknüpfen, z. B. mechanische Komponenten.</text>
					</langStringTextType>
				</description>
				<semanticId>
					<type>ExternalReference</type>
					<keys>
