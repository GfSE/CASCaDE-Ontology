          }
        },
        {
          "@id": "cas-arch:UseCase",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Use Case"
            },
            {
              "@language": "de",
              "@value": "Anwendungsfall"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Specifies what the user of a product will do in order to achieve a goal"
            },
            {
              "@language": "de",
              "@value": "Legt fest, was der Nutzer eines Produkts tut, um ein Ziel zu erreichen"
            }
          ],
          "dcterms:modified": {
            "@value": "2026-02-17T16:43:44Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          },
          "rdfs:definedBy": {
            "@id": "https://www.vdi.de/richtlinien/details/vdi-2519-blatt-1-vorgehensweise-bei-der-erstellung-von-lasten-pflichtenheften"
          }
        },
        {
          "@id": "cas-arch:Requirement",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Requirement"
            },
            {
              "@language": "de",
              "@value": "Anforderung"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Characteristics that identify the accomplishment levels needed to achieve specific objectives for a given set of conditions.\r\nRequirements can be 'must have', 'can have' and 'nice to have'.\r\nA. A condition or capability needed by a user to solve a problem or achieve an objective.\r\nB. A condition or capability that must be met or possessed by a system or system component to satisfy a contract, standard, specification, or other formally imposed document.\r\nC. A documented representation of a condition or capability as in definition (A:) or (B).\r\nhttps://intranet.prostep.org/display/PROJ/Glossary"
            },
            {
              "@language": "de",
              "@value": "Merkmale, die die erforderliche Leistung spezifizieren, um bestimmte Ziele unter bestimmten Bedingungen zu erreichen.\nAnforderungen können als \"muss\", \"kann\" und \"soll\" klassifiziert sein.\nA. Eine Bedingung oder Fähigkeit, die ein Benutzer benötigt, um ein Problem zu lösen oder ein Ziel zu erreichen.\nB. Eine Bedingung oder Fähigkeit, die ein System oder eine Systemkomponente erfüllen oder besitzen muss, um einen Vertrag, eine Norm, eine Spezifikation oder ein anderes formell vorgeschriebenes Dokument zu erfüllen.\nC. Eine dokumentierte Darstellung einer Bedingung oder Fähigkeit wie in Definition (A:) oder (B).\nhttps://intranet.prostep.org/display/PROJ/Glossary"
            }
          ],
          "dcterms:modified": {
            "@value": "2025-09-28T11:35:09Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          },
          "rdfs:definedBy": [
            {
              "@id": "https://www.dinmedia.de/de/norm/iso-iec-ieee-29148/299567544"
            },
            {
              "@id": "https://www.vdi.de/richtlinien/details/vdi-2519-blatt-1-vorgehensweise-bei-der-erstellung-von-lasten-pflichtenheften"
            },
            {
              "@id": "https://www.dinmedia.de/de/norm/can-csa-iso-iec-ieee-15288/269743351"
            }
          ]
        },
