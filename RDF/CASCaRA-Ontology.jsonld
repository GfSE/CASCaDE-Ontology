		},
		"skos:definition" : [
			{
				"@language" : "en",
				"@value" : "Represents a system, product or component failure. A failure negates a corresponding function. Malfunctions are typically managed in an FMEA."
			},
			{
				"@language" : "de",
				"@value" : "Repräsentiert eine Fehlfunktion eines Systems, Produkts oder einer Komponente. Eine Fehlfunktion negiert eine entsprechende Funktion. Fehlfunktionen werden typischerweise in einer FMEA verwaltet."
			}
			
		],
		"@context" : {
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
