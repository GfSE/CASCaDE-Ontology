        {
          "@id": "cas-val:ValidationCriterium",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Validation Criterium"
            },
            {
              "@language": "de",
              "@value": "Validierungskriterium"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A specific validation criterium as part of a validation plan."
            },
            {
              "@language": "de",
              "@value": "Ein spezifisches Validierungskriterium als Teil eines Validierungsplans."
            }
          ],
          "dcterms:modified": {
            "@value": "2025-12-01T01:51:03Z",
