                                             a cas-arch:Requirement;
                                             rdfs:label "2.2.2.2 Available Power".
cas-arch-requirement:2-2-2_Internal-Power-Supply dc:description "The Mars Rover shall have a power supply fulfilling all of the following conditions:* it contains an energy storage system* it contains an energy management system* it contains a power distribution system";
                                                 dc:identifier "_17_0_3_1_60c0217_1554373947269_839759_17516";
