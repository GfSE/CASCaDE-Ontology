	<owl:Class rdf:about="&cas-sys;SystemComponent_fulfils_Requirement">
		<rdfs:subClassOf rdf:resource="&cas-meta;Relationship"/>
		<rdfs:label xml:lang="en">System Component fulfils Requirement</rdfs:label>
		<rdfs:label xml:lang="de">Systemkomponente erfüllt Anforderung</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2026-03-03T09:00:35Z</dcterms:modified>
		<cas-meta:Object rdf:resource="&cas-arch;Requirement"/>
		<cas-meta:Subject rdf:resource="&cas-sys;SystemComponent"/>
		<skos:definition xml:lang="de">Anforderung, die durch die Komponente erfüllt wird. Gemäß Systems-Engineering-Best-Practice sollte eine Anforderung zunächst durch eine Funktion beantwortet werden, und die Funktion wird durch eine Komponente implementiert. Dieser direkte Bezug sollte daher nur verwendet werden, wenn keine Funktionen definiert wurden.</skos:definition>
		<skos:definition xml:lang="en">Requirement implemented by the component. According to systems engineering best-practice, a requirement should first be answered by a function, and the function will be implemented by a component. This direct relation should therefore only be used if no functions have been defined.</skos:definition>
	</owl:Class>
	
