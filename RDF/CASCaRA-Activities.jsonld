				"@language" : "en",
				"@value" : "Cost Calculation"
			},
			{
				"@language" : "de",
				"@value" : "Kostenkalkulation"
			}
			
		],
		"skos:definition" : {
			"@language" : "en",
			"@value" : "Includes the calculation of product cost using relevant information from product and production specifications, including dimensions, material, mass, geometric & topological complexity, surface finish including paint or coatings."
