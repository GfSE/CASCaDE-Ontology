        {
          "@id": "ProductDevelopment/ProductDesign/ElectricalMechanicalDesignCollaboration",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Electrical/Mechanical Design Collaboration"
            },
            {
              "@language": "de",
              "@value": "Zusammenarbeit Elektrik/Mechanik-Konstruktion"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "In Electrical/Mechanical Design Collaboration, both design disciplines involved will collaborate in a common 3D space in order to adjust and coordinate allocation, dimensioning and positioning of components."
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
            {
              "@id": "mech:MechanicalComponent"
            },
            {
              "@id": "mech:Body"
            },
            {
              "@id": "ee:ElectricElectronicComponent"
            },
