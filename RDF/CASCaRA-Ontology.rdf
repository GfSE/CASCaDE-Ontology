    <skos:definition xml:lang="en">Represents all kinds of tools and equipment used to manufacture parts and assemble the product.</skos:definition>
    <skos:definition xml:lang="de">Steht für alle Arten von Werkzeugen und Ausrüstungen, die zur Herstellung von Teilen und zum Zusammenbau des Produkts verwendet werden.</skos:definition>
  </owl:Class>
