          "dcterms:title": {
            "@value": "CASCaRA Domain Ontology"
          },
          "dcterms:abstract": {
            "@value": "The CASCaRA ontology provides a definition of data entities, attributes and relationships representing the Digital Thread.\\nNote that this version of the ontology is in development and may be subject to modifications without notice."
          },
          "dcterms:created": {
            "@value": "20.05.2026 08:01:59"
          },
          "owl:versionInfo": {
            "@value": "1.0"
          },
