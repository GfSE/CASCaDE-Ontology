		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Configuration"
			},
			{
				"@language" : "de",
				"@value" : "Konfiguration"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2025-11-30T21:02:09Z"
		},
		"skos:definition" : [
			{
				"@language" : "en",
				"@value" : "Represents a configuration as a context for other elements to be valid. The datamodel allows selected elements to be related to a revision, i. e. mechanical components"
			},
			{
				"@language" : "de",
				"@value" : "Repräsentiert eine Konfiguration als Kontext, in dem verknüpfte Elemente gültig sein sollen. Das Datenmodell sieht vor, ausgewählte Elemente mit einer Konfiguration zu verknüpfen, z. B. mechanische Komponenten."
			}
			
		],
		"@context" : {
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-ctx" : "http://www.omg.org/spec/CASCaRA/ontology/ContextElements/",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
