	<aas:submodels>
		<submodelElement>
			<idShort>SystemsArchitecture</idShort>
			<displayName>
				<langStringNameType>
					<language>en</language>
					<text>Systems Architecture</text>
				</langStringNameType>
				<langStringNameType>
					<language>de</language>
					<text>Systemarchitektur</text>
				</langStringNameType>
			</displayName>
			<description>
				<langStringTextType>
					<language>en</language>
					<text>Systems architecture refers to the cross-domain definition of functions and logical structures at systems level, that will be pursued in detail by the individual domains mechanical design, electric/electronic design and software design.</text>
				</langStringTextType>
			</description>
