    <skos:definition xml:lang="de">Repräsentiert ein Fügeverfahren wie z. B. Schweißen, Nieten, etc.</skos:definition>
    <skos:definition xml:lang="en">Represents a joining process type such as welding, riveting, etc.</skos:definition>
  </owl:Class>
