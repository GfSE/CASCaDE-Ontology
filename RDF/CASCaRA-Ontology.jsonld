	{
		"@id" : "cas-val:ValidationPlan",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Validation Plan"
			},
			{
				"@language" : "de",
				"@value" : "Validierungsplan"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2024-08-02T14:08:33Z"
		},
		"skos:definition" : [
			{
				"@language" : "en",
				"@value" : "A specific executable test that examines all aspects including inputs and outputs of a system and then provides a detailed description of the steps that should be taken, the results that should be achieved, and other elements that should be identified. Steps explained in a test case include all details even if they are assumed to be common knowledge. Test cases are used as a technical explanation and reference guide for systems.\u000ahttps://intranet.prostep.org/display/PROJ/Glossary"
			},
			{
				"@language" : "de",
				"@value" : "Ein spezifischer, ausführbarer Test, der alle Aspekte, einschließlich der Eingaben und Ausgaben eines Systems, untersucht und dann eine detaillierte Beschreibung der Schritte, die durchgeführt werden sollten, der Ergebnisse, die erzielt werden sollten, und anderer Elemente, die identifiziert werden sollten, liefert. Die in einem Testfall erläuterten Schritte umfassen alle Details, auch wenn sie als allgemein bekannt vorausgesetzt werden. Testfälle werden als technische Erklärung und Referenz für Systeme verwendet."
			}
			
		],
		"@context" : {
			"cas-val" : "http://www.omg.org/spec/CASCaRA/ontology/ProductValidation/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
	{
		"@id" : "cas-val:ValidationPlan_Shape",
		"@type" : "http://www.w3.org/ns/shacl#NodeShape",
		"http://www.w3.org/ns/shacl#property" : [
			{ "@id" : "dc:description_Shape" },
			{ "@id" : "dc:identifier_Shape" },
			{ "@id" : "dc:title_Shape" },
			{ "@id" : ":number_Shape" },
			{ "@id" : ":type_Shape" }
			
		],
		"http://www.w3.org/ns/shacl#targetClass" : { "@id" : "cas-val:ValidationPlan" },
