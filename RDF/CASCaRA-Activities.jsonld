	{
		"@id" : ":VerificationValidationUsingSimulation",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Verification & Validation using Simulation"
			},
			{
				"@language" : "de",
				"@value" : "Verifikation & Validierung durch Simulation"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2023-03-10T07:09:37Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "Modeling and simulation (M&S) is the domain-specific use of models (e.g., physical, mathematical, or logical representation of a system, entity, phenomenon, or process) as a basis for simulations to develop data utilized for management or technical decision making.\u000d\u000aSimulation may include finite elements analysis, fluid analysis, DMU simulation, kinematics simulation, as well as simulation based on software prototypes. It also includes X-in-the-Loop (XiL), using integrated design and simulation models and capabilities.\u000aVerification aims at the demonstration of product compliance to the specified design requirements.\u000aValidation aims at the demonstration of conformance to stakeholder requirements.\u000aDescription based on: https://en.wikipedia.org/wiki/Modeling_and_simulation, ISO 29148, ISO 15288"
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
	{
		"@id" : ":VerificationValidationUsingTest",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Verification & Validation using Test"
			},
			{
				"@language" : "de",
				"@value" : "Verifikation & Validierung durch Test"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2023-03-10T07:29:10Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "While simulation is based on virtual models, testing is based on prototypes and samples.\u000d\u000aVerification is to demonstrate product compliance to the specified design requirements. Validation is to demonstrate conformance to stakeholder requirements.\u000d\u000aDescription based on ISO 29148, resp. ISO 15288"
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	}
]
