			<displayName>
				<langStringNameType>
					<language>en</language>
					<text>Prepare Testing</text>
				</langStringNameType>
				<langStringNameType>
					<language>de</language>
					<text>Versuch vorbereiten</text>
				</langStringNameType>
			</displayName>
			<description>
				<langStringTextType>
					<language>en</language>
					<text>Testing preparation includes the definition of product requirements and functions to be validated, the specification, design and manufacturing of samples, prototypes and test rigs.</text>
				</langStringTextType>
			</description>
