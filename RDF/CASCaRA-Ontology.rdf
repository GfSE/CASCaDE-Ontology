		<rdfs:subClassOf rdf:resource="&cas-org;Actor"/>
		<rdfs:label xml:lang="de">Organisationseinheit</rdfs:label>
		<rdfs:label xml:lang="en">Organization Unit</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2025-12-13T17:00:54Z</dcterms:modified>
		<skos:definition xml:lang="en">An organization unit is part of a corporate structure. It comprises persons as well as sub-organization units.</skos:definition>
		<skos:definition xml:lang="de">Eine Organisationseinheit ist Teil einer Unternehmensstruktur. Sie umfasst sowohl Personen als auch untergeordnete Organisationseinheiten.</skos:definition>
	</owl:Class>
	
