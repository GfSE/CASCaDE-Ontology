        {
          "@id": "con:BusinessOrMissionAnalysis",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Business or Mission Analysis"
            },
            {
              "@language": "de",
              "@value": "Geschäfts- oder Einsatzanalyse"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Product Planning is the ongoing process of identifying and articulating market requirements that define a product's feature set. Product planning serves as the basis for decisions about price, distribution and promotion.\nProduct planning is the process of creating a product idea and following through on it until the product is introduced to the market. Additionally, a small company must have an exit strategy for its product in case the product does not sell.\nProduct planning entails managing the product throughout its life using various marketing strategies, including product extensions or improvements, increased distribution, price changes and promotions.\n\r\nAlso includes the identification of relevant legal requirements as well as customs and tax regulations applicable to the product and the respective target markets.\r\nDescription based on: https://en.wikipedia.org/wiki/Product_planning"
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:generated": [
            {
              "@id": "org:Role"
            },
            {
              "@id": "arch:UseCase"
            }
          ]
        },
        {
          "@id": "con:RequirementsEngineering",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Requirements Engineering"
            },
            {
              "@language": "de",
              "@value": "Anforderungsmanagement"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Requirements engineering is the process of defining, eliciting, documenting, and maintaining requirements in the engineering design process.\r\nDescription based on: https://en.wikipedia.org/wiki/Requirements_engineering"
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
            {
              "@id": "org:Role"
            },
            {
              "@id": "arch:UseCase"
            }
          ],
          "prov:generated": {
            "@id": "arch:Requirement"
          }
        },
        {
          "@id": "con:SystemsArchitecture",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Systems Architecture"
            },
            {
              "@language": "de",
              "@value": "Systemarchitektur"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Systems architecture refers to the cross-domain definition of functions and logical structures at systems level, that will be pursued in detail by the individual domains mechanical design, electric/electronic design and software design."
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
            {
              "@id": "org:Role"
            },
            {
              "@id": "arch:UseCase"
            },
            {
              "@id": "arch:StakeholderRequirement"
            }
          ],
          "prov:generated": [
            {
              "@id": "arch:Function"
            },
            {
              "@id": "sys:SystemComponent"
            },
            {
              "@id": "sys:ComponentInterface"
            },
