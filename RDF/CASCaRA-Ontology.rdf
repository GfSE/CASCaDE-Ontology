  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ContextElements/Variant">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-30T20:52:38Z</dcterms:modified>
    <rdfs:definedBy rdf:resource="https://www.dinmedia.de/de/norm/iso-iec-26580/340248389" />
    <rdfs:label xml:lang="en">Variant</rdfs:label>
    <rdfs:label xml:lang="de">Variante</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <skos:definition xml:lang="de">Repräsentiert eine Variante als Kontext, in dem verknüpfte Elemente gültig sein sollen. Das Datenmodell sieht vor, ausgewählte Elemente mit einer Variante zu verknüpfen, z. B. mechanische Komponenten.</skos:definition>
    <skos:definition xml:lang="en">Represents a variant as a context for other elements to be valid. The datamodel allows selected elements to be related to a variant, i. e. mechanical components</skos:definition>
  </owl:Class>
  <sh:NodeShape rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ContextElements/Variant_Shape">
    <sh:property rdf:resource="http://purl.org/dc/elements/1.1/description_Shape" />
    <sh:property rdf:resource="http://purl.org/dc/elements/1.1/identifier_Shape" />
    <sh:property rdf:resource="http://purl.org/dc/elements/1.1/title_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/ContextElements/Variant_includes_BendingSpecification_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/ContextElements/Variant_includes_Body_Shape" />
