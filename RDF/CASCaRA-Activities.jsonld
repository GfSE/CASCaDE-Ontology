            {
              "@id": "ee:ElectricElectronicConnection"
            }
          ]
        },
        {
          "@id": "ProductDesign",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Product Design"
            },
            {
              "@language": "de",
              "@value": "Produktentwurf"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Product Design is the specific synthesis, implentation and documentation of design solutions suggested by systems engineering.\r\nProduct design comprises the domain-specific design processes of mechanical, electrical/electronical design, and software engineering."
          },
          "dcterms:modified": {
            "@value": "2021-11-29T12:59:20Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "ProductDevelopment/VerificationValidationUsingSimulation/PlanAndPrepareSimulation",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Plan and prepare Simulation"
            },
            {
              "@language": "de",
              "@value": "Simulation planen und vorbereiten"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Planning and preparation of a simulation includes the specification of the simulation objectives based on product requirements and functions. This is followed by the definition of the simulation boundary conditions and the createion of simulation models according to simulation objectives."
            },
            {
              "@language": "de",
              "@value": "Die Planung und Vorbereitung einer Simulation umfasst die Spezifikation der Simulationsziele auf der Grundlage der Produktanforderungen und -funktionen. Es folgt die Definition der Simulationsrandbedingungen und die Erstellung von Simulationsmodellen entsprechend den Simulationszielen."
            }
          ],
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
            {
              "@id": "arch:SystemRequirement"
            },
            {
