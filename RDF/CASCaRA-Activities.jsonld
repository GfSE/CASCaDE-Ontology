	{
		"@id" : ":ProductDesign",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Product Design"
			},
			{
				"@language" : "de",
				"@value" : "Produktentwurf"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2021-11-29T12:59:20Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "Product Design is the specific synthesis, implentation and documentation of design solutions suggested by systems engineering.\u000d\u000aProduct design comprises the domain-specific design processes of mechanical, electrical/electronical design, and software engineering."
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
	{
		"@id" : ":ProductDevelopment",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Product Development"
			},
			{
				"@language" : "de",
				"@value" : "Produktentwicklung"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2022-02-18T11:15:52Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "Product development is the creation of products with new or modified characteristics that offer new or additional benefits to the customer, or comply with new or changed standards, rules and regulations.\u000d\u000aProduct development may involve modification of an existing product or its presentation or formulation of an entirely new product that satisfies a newly-defined or changed customer need or market segment.\u000d\u000aDescription based on: https://cio-wiki.org/wiki/Product_Development"
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
	{
		"@id" : "con:BusinessOrMissionAnalysis",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "prov:Activity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Business or Mission Analysis"
			},
			{
				"@language" : "de",
				"@value" : "Geschäfts- oder Einsatzanalyse"
			}
			
		],
		"skos:definition" : {
			"@language" : "en",
			"@value" : "Product Planning is the ongoing process of identifying and articulating market requirements that define a product's feature set. Product planning serves as the basis for decisions about price, distribution and promotion.\u000aProduct planning is the process of creating a product idea and following through on it until the product is introduced to the market. Additionally, a small company must have an exit strategy for its product in case the product does not sell.\u000aProduct planning entails managing the product throughout its life using various marketing strategies, including product extensions or improvements, increased distribution, price changes and promotions.\u000a\u000d\u000aAlso includes the identification of relevant legal requirements as well as customs and tax regulations applicable to the product and the respective target markets.\u000d\u000aDescription based on: https://en.wikipedia.org/wiki/Product_planning"
		},
		"prov:generated" : [
			{ "@id" : "org:Role" },
			{ "@id" : "arch:UseCase" }
			
		],
		"@context" : {
			"con" : "http://www.omg.org/spec/CASCaRA/ontology/ProductDevelopment/ConceptDefinition/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"org" : "http://www.omg.org/spec/CASCaRA/ontology/Organization/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#",
			"arch" : "http://www.omg.org/spec/CASCaRA/ontology/ProductArchitecture/",
			"prov" : "http://www.w3.org/ns/prov/"
		}
	},
