	{
		"@id" : ":MechanicalDesign",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Mechanical Design"
			},
			{
				"@language" : "de",
				"@value" : "Mechanische Konstruktion"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2023-10-22T15:48:39Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "In Mechanical Design, physical product structure, product geometry, as well as all specifications are defined.\u000d\u000aThis includes shape, dimensioning and tolerancing, material (including semi-finished parts and treatment), surface and edge specifications.\u000d\u000aMechanical design is usually conducted using a mechanical CAD system."
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
