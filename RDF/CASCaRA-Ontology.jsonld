        {
          "@id": "cas-org:Role",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Role"
            },
            {
              "@language": "de",
              "@value": "Rolle"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A defined function to be performed by a project team member, such as testing, filing, inspecting, coding.\nhttps://intranet.prostep.org/display/PROJ/Glossary"
            },
            {
              "@language": "de",
              "@value": "Eine definierte Funktion, die von einem Mitglied des Projektteams auszuführen ist, z. B. Testen, Ablegen, Prüfen, Codieren.\nhttps://intranet.prostep.org/display/PROJ/Glossary"
            }
          ],
          "dcterms:modified": {
            "@value": "2026-02-17T16:46:24Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "cas-org:Actor",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Actor"
            },
            {
              "@language": "de",
              "@value": "Akteur"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Abstract class for an actor. Derived, specific classes are person and organization unit."
            },
            {
              "@language": "de",
              "@value": "Abstrakte Klasse für einen Akteur. Abgeleitete konkrete Ausprägungen sind Person und Organisationseinheit."
            }
          ],
          "dcterms:modified": {
            "@value": "2025-03-10T05:51:37Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "cas-org:Person",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Person"
            },
            {
              "@language": "de",
              "@value": "Person"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Represents a real person, but may also be a system user that appears in source data. The FOAF (Friend of a Friend) Ontology has been considered, but is not used as it does not provide a structured representation for firstname, lastname and title of a person."
            },
            {
              "@language": "de",
              "@value": "Repräsentiert eine natürliche Person, kann aber auch einen System-User repräsentieren, der in Quelldaten erscheint.\nDie FOAF-Ontologie (Friend of a Friend) wurde geprüft, wird aber nicht verwendet, da sie keine strukturierte Darstellung von Vorname, Nachname und Titel einer Person ermöglicht."
            }
          ],
          "dcterms:modified": {
            "@value": "2025-12-13T15:12:19Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": [
            {
              "@id": "cas:Entity"
            },
            {
              "@id": "cas-org:Actor"
            }
          ]
        },
        {
          "@id": "cas-org:OrganizationUnit",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Organization Unit"
            },
            {
              "@language": "de",
              "@value": "Organisationseinheit"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "An organization unit is part of a corporate structure. It comprises persons as well as sub-organization units."
            },
            {
              "@language": "de",
              "@value": "Eine Organisationseinheit ist Teil einer Unternehmensstruktur. Sie umfasst sowohl Personen als auch untergeordnete Organisationseinheiten."
            }
          ],
          "dcterms:modified": {
            "@value": "2025-12-13T17:00:54Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": [
            {
              "@id": "cas:Entity"
            },
            {
              "@id": "cas-org:Actor"
            }
          ]
        },
        {
          "@id": "cas-org:Plant",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Plant"
            },
            {
              "@language": "de",
              "@value": "Werk"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A plant that provides manufacturing capabilities and resources and executes manufacuring operations."
            },
            {
              "@language": "de",
              "@value": "Ein Produktionswerk, das Fertigungskapazitäten und Ressourcen bereitstellt und Fertigungsvorgänge ausführt."
            }
          ],
          "dcterms:modified": {
            "@value": "2025-12-24T13:12:03Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": [
            {
              "@id": "cas:Entity"
            },
            {
              "@id": "cas-org:OrganizationUnit"
            }
          ]
        },
        {
          "@id": "cas-org:Event",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Event"
            },
            {
              "@language": "de",
              "@value": "Ereignis"
            }
          ],
          "dcterms:modified": {
            "@value": "2026-03-20T11:29:13Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "cas-org:Task",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Task"
            },
            {
              "@language": "de",
              "@value": "Aufgabe"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A task is a definite piece of work assigned to a person or organisation"
            },
            {
              "@language": "de",
              "@value": "Eine Aufgabe ist eine definierte Handlung, die einer Person oder Organisation zugewiesen wird."
            }
          ],
          "dcterms:modified": {
            "@value": "2026-04-13T11:37:38Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": [
            {
              "@id": "cas:Entity"
            },
            {
              "@id": "cas-org:Event"
            }
          ]
        },
        {
          "@id": "cas-org:Project",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Project"
            },
            {
              "@language": "de",
              "@value": "Projekt"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Represents a project or sub-project"
            },
            {
              "@language": "de",
              "@value": "Repräsentiert ein Projekt oder Teilprojekt"
            }
          ],
          "dcterms:modified": {
            "@value": "2026-03-19T00:51:47Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": [
            {
              "@id": "cas:Entity"
            },
            {
              "@id": "cas-org:Task"
            }
          ]
        },
        {
          "@id": "cas-org:Place",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Place"
            },
            {
              "@language": "de",
              "@value": "Ort"
            }
          ],
          "dcterms:modified": {
            "@value": "2026-04-01T17:55:56Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
