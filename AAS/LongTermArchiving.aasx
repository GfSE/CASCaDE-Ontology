			<displayName>
				<langStringNameType>
					<language>en</language>
					<text>Long-Term Archiving</text>
				</langStringNameType>
				<langStringNameType>
					<language>de</language>
					<text>Langzeitarchivierung</text>
				</langStringNameType>
			</displayName>
			<description>
				<langStringTextType>
					<language>en</language>
					<text>For long-term archiving, all product information must be configured and stored in a retrievable way. Product information includes domain-specifc models, relations between models and model entities, and meta-data about the documents and models.</text>
				</langStringTextType>
			</description>
