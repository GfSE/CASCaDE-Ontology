        {
          "@id": "cas-sys:SystemComponent_fulfils_Requirement",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "System Component fulfils Requirement"
            },
            {
              "@language": "de",
              "@value": "Systemkomponente erfüllt Anforderung"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Requirement implemented by the component. According to systems engineering best-practice, a requirement should first be answered by a function, and the function will be implemented by a component. This direct relation should therefore only be used if no functions have been defined."
            },
            {
              "@language": "de",
              "@value": "Anforderung, die durch die Komponente erfüllt wird. Gemäß Systems-Engineering-Best-Practice sollte eine Anforderung zunächst durch eine Funktion beantwortet werden, und die Funktion wird durch eine Komponente implementiert. Dieser direkte Bezug sollte daher nur verwendet werden, wenn keine Funktionen definiert wurden."
            }
          ],
          "dcterms:modified": {
            "@value": "2026-03-03T09:00:35Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Relationship"
          },
          "rdfs:subPropertyOf": {
            "@id": "cas:linksSource"
          },
          "rdfs:domain": {
            "@id": "cas-arch:Requirement"
          }
        },
