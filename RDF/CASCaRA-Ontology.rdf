    <rdfs:definedBy rdf:resource="https://www.dinmedia.de/de/norm/din-en-61508-1/135302584" />
    <rdfs:definedBy rdf:resource="https://www.dinmedia.de/de/norm/iso-21448/356927331" />
    <rdfs:definedBy rdf:resource="https://www.dinmedia.de/de/norm/iso-26262-1/300423910" />
    <rdfs:definedBy rdf:resource="https://www.dinmedia.de/de/norm/iso-iec-20246/271358565" />
    <rdfs:definedBy rdf:resource="https://www.sae.org/standards/arp4754b-guidelines-development-civil-aircraft-systems" />
    <rdfs:definedBy rdf:resource="https://www.sae.org/standards/arp4761a-guidelines-conducting-safety-assessment-process-civil-aircraft-systems-equipment" />
    <rdfs:label xml:lang="de">Abweichung</rdfs:label>
    <rdfs:label xml:lang="en">Deviation</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <skos:definition xml:lang="de">Repräsentiert eine Abweichung eines Systems, Produkts oder einer Komponente. Eine Abweichung beeinträchtigt eine Funktion. Abweichungen werden typischerweise in einer FMEA verwaltet.</skos:definition>
    <skos:definition xml:lang="en">Represents a system, product or component deviation. A deviation affects a function. Deviations are typically managed in an FMEA.</skos:definition>
  </owl:Class>
