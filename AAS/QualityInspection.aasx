			<displayName>
				<langStringNameType>
					<language>en</language>
					<text>Quality Inspection</text>
				</langStringNameType>
				<langStringNameType>
					<language>de</language>
					<text>Qualitätskontrolle</text>
				</langStringNameType>
			</displayName>
			<description>
				<langStringTextType>
					<language>en</language>
					<text>Includes the inspection of single parts, components or products during or after the manufacturing process, as well as the documentation of inspection results.</text>
