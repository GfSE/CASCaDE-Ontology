          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Parts Manufacturing"
            },
            {
              "@language": "de",
              "@value": "Teilefertigung"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Manufacturing of single parts using a variety of production processes and methods, each with specific sets of data, such as CNC programs, bending specification, holes specifications, joining features, etc."
          },
          "rdfs:subClassOf": {
