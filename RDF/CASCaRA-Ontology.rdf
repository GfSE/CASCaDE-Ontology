		<zzzns0001:property rdf:resource="&dc;title_Shape"/>
		<zzzns0001:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/number_Shape"/>
		<zzzns0001:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/type_Shape"/>
		<zzzns0001:targetClass rdf:resource="&cas-val;ValidationPlan"/>
	</zzzns0001:NodeShape>
	
