        {
          "@id": "cas-val:ValidationPlan",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Validation Plan"
            },
            {
              "@language": "de",
              "@value": "Validierungsplan"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A specific executable test that examines all aspects including inputs and outputs of a system and then provides a detailed description of the steps that should be taken, the results that should be achieved, and other elements that should be identified. Steps explained in a test case include all details even if they are assumed to be common knowledge. Test cases are used as a technical explanation and reference guide for systems.\nhttps://intranet.prostep.org/display/PROJ/Glossary"
            },
            {
              "@language": "de",
              "@value": "Ein spezifischer, ausführbarer Test, der alle Aspekte, einschließlich der Eingaben und Ausgaben eines Systems, untersucht und dann eine detaillierte Beschreibung der Schritte, die durchgeführt werden sollten, der Ergebnisse, die erzielt werden sollten, und anderer Elemente, die identifiziert werden sollten, liefert. Die in einem Testfall erläuterten Schritte umfassen alle Details, auch wenn sie als allgemein bekannt vorausgesetzt werden. Testfälle werden als technische Erklärung und Referenz für Systeme verwendet."
            }
          ],
          "dcterms:modified": {
            "@value": "2024-08-02T14:08:33Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
