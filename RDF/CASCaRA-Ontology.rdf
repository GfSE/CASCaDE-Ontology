	<owl:Class rdf:about="&cas-arch;Function">
		<rdfs:subClassOf rdf:resource="&cas-meta;Entity"/>
		<rdfs:label xml:lang="en">Function</rdfs:label>
		<rdfs:label xml:lang="de">Funktion</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2026-03-30T20:45:48Z</dcterms:modified>
		<skos:definition xml:lang="en">A system, product or component function describes the way a system works or performs a specific task.</skos:definition>
		<skos:definition xml:lang="de">Eine System-, Produkt- oder Komponentenfunktion beschreibt die Art und Weise, wie ein System arbeitet oder eine bestimmte Aufgabe ausführt.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&cas-arch;FunctionFailure">
		<rdfs:subClassOf rdf:resource="&cas-meta;Entity"/>
		<rdfs:label xml:lang="de">Fehlfunktion</rdfs:label>
		<rdfs:label xml:lang="en">Function Failure</rdfs:label>
		<dcterms:modified rdf:datatype="&xsd;dateTime">2025-12-01T01:20:45Z</dcterms:modified>
		<skos:definition xml:lang="en">Represents a system, product or component failure. A failure negates a corresponding function. Malfunctions are typically managed in an FMEA.</skos:definition>
		<skos:definition xml:lang="de">Repräsentiert eine Fehlfunktion eines Systems, Produkts oder einer Komponente. Eine Fehlfunktion negiert eine entsprechende Funktion. Fehlfunktionen werden typischerweise in einer FMEA verwaltet.</skos:definition>
	</owl:Class>
	
