    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <skos:definition xml:lang="en">Defines what verification and validation measures are used from product development through ramp-up to series production.</skos:definition>
    <skos:definition xml:lang="de">Legt fest, welche Verifizierungs- und Validierungsmaßnahmen von der Produktentwicklung über den Hochlauf bis zur Serienproduktion verwendet werden.</skos:definition>
  </owl:Class>
