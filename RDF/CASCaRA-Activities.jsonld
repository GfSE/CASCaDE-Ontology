        {
          "@id": "ProductDevelopment/ProductDesign/SoftwareEngineering",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Software Engineering"
            },
            {
              "@language": "de",
              "@value": "Softwareentwicklung"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "In Software Engineering, embedded software is developed that will connect the product to the user, as well as to other products and systems.\nFor configuration reasons it may be that software is treated a part to be considered in Bills of Material of products or systems and to be configured related to mechanical or electronic configurations of a system."
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
