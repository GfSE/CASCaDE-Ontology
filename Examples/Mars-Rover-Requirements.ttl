                                                 :number "2.7";
                                                 a cas-arch:Requirement;
                                                 rdfs:label "2.7 Mars Rover Capabilities".
cas-arch-requirement:2-8-1_Landing-Temperatures dc:description "The Mars Rover shall resist temperatures of not more than 100°C for not more than 7 minutes while staying full functional.";
                                                dc:identifier "_2021x_2_8d501e7_1710150476050_13127_5658";
                                                dc:title "Landing Temperatures";
