        {
          "@id": "ProductDevelopment/VerificationValidationUsingSimulation/PerformAndDocumentSimulation",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Perform and document Simulation"
            },
            {
              "@language": "de",
              "@value": "Simulation durchführen und dokumentieren"
            }
          ],
          "skos:definition": {
            "@language": "en",
