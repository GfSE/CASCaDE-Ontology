		},
		"skos:definition" : [
			{
				"@language" : "en",
				"@value" : "Represents a variant as a context for other elements to be valid. The datamodel allows selected elements to be related to a variant, i. e. mechanical components"
			},
			{
				"@language" : "de",
				"@value" : "Repräsentiert eine Variante als Kontext, in dem verknüpfte Elemente gültig sein sollen. Das Datenmodell sieht vor, ausgewählte Elemente mit einer Variante zu verknüpfen, z. B. mechanische Komponenten."
			}
			
		],
		"@context" : {
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
