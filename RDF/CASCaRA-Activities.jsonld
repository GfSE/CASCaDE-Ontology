        {
          "@id": "VerificationValidationUsingTest",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Verification & Validation using Test"
            },
            {
              "@language": "de",
              "@value": "Verifikation & Validierung durch Test"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "While simulation is based on virtual models, testing is based on prototypes and samples.\r\nVerification is to demonstrate product compliance to the specified design requirements. Validation is to demonstrate conformance to stakeholder requirements.\r\nDescription based on ISO 29148, resp. ISO 15288"
          },
          "dcterms:modified": {
            "@value": "2023-03-10T07:29:10Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "ProductDevelopment",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Product Development"
            },
            {
              "@language": "de",
              "@value": "Produktentwicklung"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Product development is the creation of products with new or modified characteristics that offer new or additional benefits to the customer, or comply with new or changed standards, rules and regulations.\r\nProduct development may involve modification of an existing product or its presentation or formulation of an entirely new product that satisfies a newly-defined or changed customer need or market segment.\r\nDescription based on: https://cio-wiki.org/wiki/Product_Development"
          },
          "dcterms:modified": {
            "@value": "2022-02-18T11:15:52Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
