            },
            {
              "@id": "https://www.dinmedia.de/de/norm/iso-iec-20246/271358565"
            }
          ]
        },
        {
          "@id": "cas-arch:SystemBehavior",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "System Behavior"
            },
            {
              "@language": "de",
              "@value": "Systemverhalten"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "Behavior of a system, correlating an output parameter to an input parameter"
            },
            {
              "@language": "de",
              "@value": "Verhalten eines Systems, bei dem ein Ausgangsparameter mit einem Eingangsparameter in Zusammenhang steht"
            }
          ],
          "dcterms:modified": {
