	{
		"@id" : ":ConceptDefinition",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "cas-meta:Entity" },
		"rdfs:label" : [
			{
				"@language" : "en",
				"@value" : "Concept definition"
			},
			{
				"@language" : "de",
				"@value" : "Konzeptdefinition"
			}
			
		],
		"dcterms:modified" : {
			"@type" : "xsd:dateTime",
			"@value" : "2022-02-18T11:17:54Z"
		},
		"skos:definition" : {
			"@language" : "en",
			"@value" : "In conceptual design, new products or systems are defined through requirements and specified through a functional structure in mechanical, electrics/electronics, and software domains. A logical structure specifies the future product architecture in order to implement the specified functions.\u000d\u000aBesides new products, existing products may be changed or modified significantly to better comply with customer needs, or to attract new customers. Eventually, the product may be changed or adopted to comply to new standards, regulations or laws.\u000d\u000aConceptual design is usually performed at a high abstraction level and low level of detail, using parameter studies, system models, and rough geometry, if any.\u000d\u000aFor the Digital Data Package, model-based methods and data for product conceptual design are assumed."
		},
		"@context" : {
			"" : "http://www.omg.org/spec/CASCaRA/ontology/",
			"rdf" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
			"owl" : "http://www.w3.org/2002/07/owl#",
			"cas-meta" : "http://www.omg.org/spec/CASCaRA/metamodel/",
			"dcterms" : "http://purl.org/dc/terms/",
			"skos" : "http://www.w3.org/2004/02/skos/core#",
			"rdfs" : "http://www.w3.org/2000/01/rdf-schema#"
		}
	},
	{
		"@id" : ":LongTermArchiving",
		"@type" : "owl:Class",
		"rdfs:subClassOf" : { "@id" : "prov:Activity" },
		"rdfs:label" : [
			{
				"@language" : "de",
				"@value" : "Langzeitarchivierung"
			},
			{
				"@language" : "en",
				"@value" : "Long-Term Archiving"
			}
			
		],
		"skos:definition" : {
			"@language" : "en",
			"@value" : "For long-term archiving, all product information must be configured and stored in a retrievable way. Product information includes domain-specifc models, relations between models and model entities, and meta-data about the documents and models."
		},
		"prov:used" : [
			{ "@id" : "proc:JoiningProcess" },
			{ "@id" : "arch:Function" },
			{ "@id" : "arch:FunctionFailure" },
			{ "@id" : "arch:StakeholderRequirement" },
			{ "@id" : "arch:SystemRequirement" },
			{ "@id" : "mech:Body" },
