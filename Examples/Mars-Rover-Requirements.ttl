                                                a cas-arch:Requirement;
                                                rdfs:label "2.8.2 Landing Deceleration".
cas-arch-requirement:2-8-3_Landing-speed dc:description "The Mars Rover shall be full operable after a landing on Mars with the following conditions beeing true:* The vertical speed at ground contact is not higher than 1 m/s* The horizontal speed at graund contact is not higher than 1 m/s";
                                         dc:identifier "_2021x_2_8d501e7_1710150880576_958104_5666";
                                         dc:title "Landing speed";
