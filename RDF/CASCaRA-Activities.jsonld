        {
          "@id": "MechanicalDesign",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Mechanical Design"
            },
            {
              "@language": "de",
              "@value": "Mechanische Konstruktion"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "In Mechanical Design, physical product structure, product geometry, as well as all specifications are defined.\r\nThis includes shape, dimensioning and tolerancing, material (including semi-finished parts and treatment), surface and edge specifications.\r\nMechanical design is usually conducted using a mechanical CAD system."
          },
          "dcterms:modified": {
            "@value": "2023-10-22T15:48:39Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "ProductDevelopment/ProductDesign/ElectricalElectronicalDesign",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Electrical/Electronical Design"
            },
            {
              "@language": "de",
              "@value": "Elektrik-/Elektronikentwicklung"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "In Electrical/Electronic Design, all electrical and electronic products functions will be implemented through electrical and electonic components selection and allocation, circuit board design, and wire and harness routing.\r\nElectrical/Electronic Design is usually performed using an electrical/electronic CAD system."
          },
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
