        },
        {
          "@id": "ConceptDefinition",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Concept definition"
            },
            {
              "@language": "de",
              "@value": "Konzeptdefinition"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "In conceptual design, new products or systems are defined through requirements and specified through a functional structure in mechanical, electrics/electronics, and software domains. A logical structure specifies the future product architecture in order to implement the specified functions.\r\nBesides new products, existing products may be changed or modified significantly to better comply with customer needs, or to attract new customers. Eventually, the product may be changed or adopted to comply to new standards, regulations or laws.\r\nConceptual design is usually performed at a high abstraction level and low level of detail, using parameter studies, system models, and rough geometry, if any.\r\nFor the Digital Data Package, model-based methods and data for product conceptual design are assumed."
          },
          "dcterms:modified": {
            "@value": "2022-02-18T11:17:54Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
        {
          "@id": "mec:DefineJoiningElements",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Define Joining Elements"
            },
            {
              "@language": "de",
              "@value": "Fügeverbindungen definieren"
            }
          ],
          "rdfs:subClassOf": {
            "@id": "prov:Activity"
          },
          "prov:used": [
            {
