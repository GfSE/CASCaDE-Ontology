    <rdfs:label xml:lang="en">Configuration</rdfs:label>
    <rdfs:label xml:lang="de">Konfiguration</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <skos:definition xml:lang="de">Repräsentiert eine Konfiguration als Kontext, in dem verknüpfte Elemente gültig sein sollen. Das Datenmodell sieht vor, ausgewählte Elemente mit einer Konfiguration zu verknüpfen, z. B. mechanische Komponenten.</skos:definition>
    <skos:definition xml:lang="en">Represents a configuration as a context for other elements to be valid. The datamodel allows selected elements to be related to a revision, i. e. mechanical components</skos:definition>
  </owl:Class>
