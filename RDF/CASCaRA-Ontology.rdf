  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ContextElements/Configuration">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-30T21:02:09Z</dcterms:modified>
