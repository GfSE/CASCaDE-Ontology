  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain/ControlPlan">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-28T22:15:05Z</dcterms:modified>
