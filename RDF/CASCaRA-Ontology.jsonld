        {
          "@id": "cas-arch:Function",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Function"
            },
            {
              "@language": "de",
              "@value": "Funktion"
            }
          ],
          "skos:definition": [
            {
              "@language": "en",
              "@value": "A system, product or component function describes the way a system works or performs a specific task."
            },
            {
              "@language": "de",
              "@value": "Eine System-, Produkt- oder Komponentenfunktion beschreibt die Art und Weise, wie ein System arbeitet oder eine bestimmte Aufgabe ausführt."
            }
          ],
          "dcterms:modified": {
            "@value": "2026-04-01T23:15:16Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
