        {
          "@id": "VerificationValidationUsingSimulation",
          "@type": "owl:Class",
          "rdfs:label": [
            {
              "@language": "en",
              "@value": "Verification & Validation using Simulation"
            },
            {
              "@language": "de",
              "@value": "Verifikation & Validierung durch Simulation"
            }
          ],
          "skos:definition": {
            "@language": "en",
            "@value": "Modeling and simulation (M&S) is the domain-specific use of models (e.g., physical, mathematical, or logical representation of a system, entity, phenomenon, or process) as a basis for simulations to develop data utilized for management or technical decision making.\r\nSimulation may include finite elements analysis, fluid analysis, DMU simulation, kinematics simulation, as well as simulation based on software prototypes. It also includes X-in-the-Loop (XiL), using integrated design and simulation models and capabilities.\nVerification aims at the demonstration of product compliance to the specified design requirements.\nValidation aims at the demonstration of conformance to stakeholder requirements.\nDescription based on: https://en.wikipedia.org/wiki/Modeling_and_simulation, ISO 29148, ISO 15288"
          },
          "dcterms:modified": {
            "@value": "2023-03-10T07:09:37Z",
            "@type": "xsd:dateTime"
          },
          "rdfs:subClassOf": {
            "@id": "cas:Entity"
          }
        },
