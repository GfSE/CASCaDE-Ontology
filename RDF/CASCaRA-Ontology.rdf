  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-12-13T15:12:19Z</dcterms:modified>
    <rdfs:label xml:lang="de">Person</rdfs:label>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/metamodel/Entity" />
    <rdfs:subClassOf rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/Actor" />
    <skos:definition xml:lang="de">Repräsentiert eine natürliche Person, kann aber auch einen System-User repräsentieren, der in Quelldaten erscheint.
Die FOAF-Ontologie (Friend of a Friend) wurde geprüft, wird aber nicht verwendet, da sie keine strukturierte Darstellung von Vorname, Nachname und Titel einer Person ermöglicht.</skos:definition>
    <skos:definition xml:lang="en">Represents a real person, but may also be a system user that appears in source data. The FOAF (Friend of a Friend) Ontology has been considered, but is not used as it does not provide a structured representation for firstname, lastname and title of a person.</skos:definition>
  </owl:Class>
  <sh:NodeShape rdf:about="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person_Shape">
    <sh:property rdf:resource="http://purl.org/dc/elements/1.1/description_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person_memberOf_OrganizationUnit_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/firstname_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/lastname_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/title_Shape" />
    <sh:property rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/number_Shape" />
    <sh:targetClass rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person" />
  </sh:NodeShape>
  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person_memberOf_OrganizationUnit">
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-09-28T11:33:03Z</dcterms:modified>
    <cas-meta:Object rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/OrganizationUnit" />
    <cas-meta:Subject rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/Organization/Person" />
