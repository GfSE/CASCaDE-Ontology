    <sh:targetClass rdf:resource="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain/ControlPlan" />
  </sh:NodeShape>
  <owl:Class rdf:about="http://www.omg.org/spec/CASCaRA/ontology/ManufacturingSupplyChain/ManufacturingEquipmentComponent">
